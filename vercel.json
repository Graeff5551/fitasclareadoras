{
  "version": 2,
  "buildCommand": "npm install --include=optional && vite build",
  "outputDirectory": "dist",
  "builds": [
    {
      "src": "servidor.ts",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "servidor.ts"
    },
    {
      "src": "/(.*)",
      "dest": "dist/$1"
    }
  ]
}
